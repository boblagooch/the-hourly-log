rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /submissions/{docId} {
      // Anyone (staff) can create a submission — no login required
      allow create: if
        request.resource.data.keys().hasAll(['category', 'timestamp']) &&
        request.resource.data.category in ['shift', 'shoutout', 'suggestion', 'concern'] &&
        request.resource.data.timestamp is string;

      // Only signed-in admins can read submissions
      allow read: if request.auth != null;

      // Nobody can edit or delete a submission after it's created
      allow update, delete: if false;
    }

    // Block access to every other collection
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
